{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisales.com/schemas/events/LeadConvertedToCustomer.v1.json",
  "title": "LeadConvertedToCustomer v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "eventType", "eventVersion", "tenantId", "aggregateId", "occurredAt", "correlationId", "customerName", "leadId", "linkedExisting"],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {"const": "LeadConvertedToCustomer"},
    "eventVersion": {"const": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "aggregateId": {"type": "string", "minLength": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "customerName": {"type": "string"},
    "leadId": {"type": "string"},
    "linkedExisting": {"type": "boolean"}
  }
}
