{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisales.com/schemas/events/NotificationSent.v1.json",
  "title": "NotificationSent v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "eventType", "eventVersion", "tenantId", "aggregateId", "occurredAt", "correlationId", "channel", "recipient", "templateId"],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {"const": "NotificationSent"},
    "eventVersion": {"const": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "aggregateId": {"type": "string", "minLength": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "channel": {"type": "string"},
    "recipient": {"type": "string"},
    "templateId": {"type": "string"}
  }
}
