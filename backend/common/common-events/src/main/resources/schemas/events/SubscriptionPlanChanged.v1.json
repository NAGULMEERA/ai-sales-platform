{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisales.com/schemas/events/SubscriptionPlanChanged.v1.json",
  "title": "SubscriptionPlanChanged v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "eventType", "eventVersion", "tenantId", "aggregateId", "occurredAt", "correlationId", "previousPlan", "newPlan"],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {"const": "SubscriptionPlanChanged"},
    "eventVersion": {"const": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "aggregateId": {"type": "string", "minLength": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "previousPlan": {"type": "string"},
    "newPlan": {"type": "string"},
    "externalSubscriptionId": {"type": "string"}
  }
}
