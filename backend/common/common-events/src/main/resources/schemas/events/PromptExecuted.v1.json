{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisales.com/schemas/events/PromptExecuted.v1.json",
  "title": "PromptExecuted v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "eventType", "eventVersion", "tenantId", "aggregateId", "occurredAt", "correlationId", "promptCode", "promptVersion", "provider", "model"],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {"const": "PromptExecuted"},
    "eventVersion": {"const": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "aggregateId": {"type": "string", "minLength": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "promptCode": {"type": "string", "minLength": 1},
    "promptVersion": {"type": "string", "minLength": 1},
    "provider": {"type": "string", "minLength": 1},
    "model": {"type": "string", "minLength": 1},
    "confidence": {"type": "string"},
    "businessReference": {"type": "string"}
  }
}
