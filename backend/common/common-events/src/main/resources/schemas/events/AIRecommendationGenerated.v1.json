{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisales.com/schemas/events/AIRecommendationGenerated.v1.json",
  "title": "AIRecommendationGenerated v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "eventType", "eventVersion", "tenantId", "aggregateId", "occurredAt", "correlationId", "recommendation"],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {"const": "AIRecommendationGenerated"},
    "eventVersion": {"const": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "aggregateId": {"type": "string", "minLength": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "recommendationType": {"type": "string"},
    "recommendation": {"type": "string"},
    "confidence": {"type": "string"},
    "businessReference": {"type": "string"}
  }
}
