{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisales.com/schemas/events/AuditRecorded.v1.json",
  "title": "AuditRecorded v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "eventType", "eventVersion", "tenantId", "aggregateId", "occurredAt", "correlationId", "action", "resourceType", "resourceId"],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {"const": "AuditRecorded"},
    "eventVersion": {"const": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "aggregateId": {"type": "string", "minLength": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "userId": {"type": "string"},
    "action": {"type": "string", "minLength": 1},
    "resourceType": {"type": "string"},
    "resourceId": {"type": "string", "minLength": 1},
    "detailsJson": {"type": "string"}
  }
}
