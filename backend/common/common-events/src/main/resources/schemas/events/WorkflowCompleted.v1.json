{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisales.com/schemas/events/WorkflowCompleted.v1.json",
  "title": "WorkflowCompleted v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "eventType", "eventVersion", "tenantId", "aggregateId", "occurredAt", "correlationId", "definitionKey", "businessKey"],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {"const": "WorkflowCompleted"},
    "eventVersion": {"const": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "aggregateId": {"type": "string", "minLength": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "definitionKey": {"type": "string", "minLength": 1},
    "businessKey": {"type": "string", "minLength": 1}
  }
}
