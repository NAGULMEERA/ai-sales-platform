{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisales.com/schemas/events/TenantCreated.v1.json",
  "title": "TenantCreated v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "eventType", "eventVersion", "tenantId", "aggregateId", "occurredAt", "correlationId", "tenantName", "slug", "plan", "industry"],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {"const": "TenantCreated"},
    "eventVersion": {"const": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "aggregateId": {"type": "string", "minLength": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "tenantName": {"type": "string"},
    "slug": {"type": "string"},
    "plan": {"type": "string"},
    "industry": {"type": "string"}
  }
}
