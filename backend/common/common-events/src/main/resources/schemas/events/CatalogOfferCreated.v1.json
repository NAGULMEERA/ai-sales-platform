{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisales.com/schemas/events/CatalogOfferCreated.v1.json",
  "title": "CatalogOfferCreated v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "eventType", "eventVersion", "tenantId", "aggregateId", "occurredAt", "correlationId", "productId", "code", "currency", "unitPrice", "status"],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
