{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisales.com/schemas/events/AIQualificationCompleted.v1.json",
  "title": "AIQualificationCompleted v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "eventType", "eventVersion", "tenantId", "aggregateId", "occurredAt", "correlationId", "promptCode", "recommendation", "cacheHit"],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {"const": "AIQualificationCompleted"},
    "eventVersion": {"const": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "aggregateId": {"type": "string", "minLength": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "promptCode": {"type": "string"},
    "promptVersion": {"type": "string"},
    "provider": {"type": "string"},
    "model": {"type": "string"},
    "recommendation": {"type": "string"},
    "qualificationScore": {"type": "string"},
    "confidenceScore": {"type": "string"},
    "leadId": {"type": "string"},
    "cacheHit": {"type": "boolean"}
  }
}
