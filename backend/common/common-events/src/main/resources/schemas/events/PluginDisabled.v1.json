{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisales.com/schemas/events/PluginDisabled.v1.json",
  "title": "PluginDisabled v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "eventType", "eventVersion", "tenantId", "aggregateId", "occurredAt", "correlationId", "pluginKey", "pluginType", "pluginVersion"],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {"const": "PluginDisabled"},
    "eventVersion": {"const": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "aggregateId": {"type": "string", "minLength": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "pluginKey": {"type": "string", "minLength": 1},
    "pluginType": {"type": "string", "minLength": 1},
    "pluginVersion": {"type": "string", "minLength": 1}
  }
}
