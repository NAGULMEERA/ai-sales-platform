{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisales.com/schemas/events/LeadMerged.v1.json",
  "title": "LeadMerged v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "eventType", "eventVersion", "tenantId", "aggregateId", "occurredAt", "correlationId", "leadName", "mergedLeadId", "survivorLeadId"],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {"const": "LeadMerged"},
    "eventVersion": {"const": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "aggregateId": {"type": "string", "minLength": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "leadName": {"type": "string"},
    "mergedLeadId": {"type": "string"},
    "survivorLeadId": {"type": "string"}
  }
}
