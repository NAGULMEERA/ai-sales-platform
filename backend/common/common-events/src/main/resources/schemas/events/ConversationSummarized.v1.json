{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aisales.com/schemas/events/ConversationSummarized.v1.json",
  "title": "ConversationSummarized v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["eventId", "eventType", "eventVersion", "tenantId", "aggregateId", "occurredAt", "correlationId", "conversationId"],
  "properties": {
    "eventId": {"type": "string", "minLength": 1},
    "eventType": {"const": "ConversationSummarized"},
    "eventVersion": {"const": 1},
    "tenantId": {"type": "string", "minLength": 1},
    "aggregateId": {"type": "string", "minLength": 1},
    "occurredAt": {"type": "string", "format": "date-time"},
    "correlationId": {"type": "string", "minLength": 1},
    "conversationId": {"type": "string"},
    "leadId": {"type": "string"},
    "executionId": {"type": "string"},
    "sentiment": {"type": "string"},
    "intent": {"type": "string"}
  }
}
