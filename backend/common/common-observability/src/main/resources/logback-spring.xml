<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        Platform-wide structured (JSON) logging, shared by every microservice via
        common-observability -> common-starter. Do not add a per-service
        logback-spring.xml; extend this one instead (Rule 08 - Observability Governance).
    -->

    <springProperty scope="local" name="serviceName" source="spring.application.name" defaultValue="ai-sales-platform"/>
    <springProperty scope="local" name="environment" source="spring.profiles.active" defaultValue="default"/>
    <springProperty scope="local" name="appVersion" source="aisales.api.version" defaultValue="1.0.0"/>

    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSXXX</timestampPattern>
            <customFields>{"service":"${serviceName}","environment":"${environment}","version":"${appVersion}"}</customFields>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <message>message</message>
                <thread>thread</thread>
                <logger>logger</logger>
                <level>level</level>
                <levelValue>[ignore]</levelValue>
                <version>[ignore]</version>
                <stackTrace>stack_trace</stackTrace>
            </fieldNames>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="JSON_CONSOLE"/>
    </root>

</configuration>
